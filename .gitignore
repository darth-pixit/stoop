# Dependencies
node_modules/

# Capacitor native projects (ios/, android/) ARE committed — the stoop:// deep
# link and camera/motion permissions are pre-wired in them. Each folder ships
# its own .gitignore excluding build outputs, Pods, and cap-sync-copied assets.
# Run `npx cap sync` after cloning to populate those before building.

# Local secrets — real Supabase/OAuth values live here, never committed.
www/js/config.local.js
.env
.env.*

# esbuild vendoring scratch
scripts/.supabase-entry.mjs

# OS / editor cruft
.DS_Store
*.log
